# direnv configuration for platform-k8s-demo
#
# Key behavior: GITHUB_BRANCH is auto-detected from the current git branch.
# direnv watches .git/HEAD, so switching branches automatically updates the
# variable — no manual intervention needed.
#
# This is what enables per-developer cluster isolation: each developer's
# bootstrap uses their current feature branch, and their Flux GitRepository
# tracks that branch instead of a shared dev branch.

# Watch git HEAD to auto-detect branch changes
watch_file .git/HEAD
watch_file .git/refs/heads

# Repository identity
export GITHUB_REPO="${GITHUB_REPO:-platform-k8s-demo}"
export GITHUB_OWNER="${GITHUB_OWNER:-your-org-here}"

# Auto-detect git branch — cached by direnv, refreshes on branch switch
GITHUB_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'main')
export GITHUB_BRANCH

# Dev cluster name
export CLUSTER_NAME="dev-cluster"
export NAMESPACE_PREFIX="dev"
export ENVIRONMENT="dev"
export DOMAIN="dev-cluster.lan"

# Load user-specific credentials (GITHUB_TOKEN, GITHUB_USER, etc.)
# Create .envrc.${USER} locally — it is gitignored
source_env_if_exists ".envrc.${USER}"

# Add scripts to PATH
PATH_add manual/scripts
